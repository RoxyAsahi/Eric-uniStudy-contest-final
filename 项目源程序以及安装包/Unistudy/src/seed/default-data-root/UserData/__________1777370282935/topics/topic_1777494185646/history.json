ase-out 0.6s both;\">\n      <span style=\"display: inline-block; border: 2px solid #b22222; color: #b22222; font-size: 14px; padding: 4px 8px; letter-spacing: 2px; transform: rotate(3deg); font-weight: bold;\">东坡居士</span>\n    </div>\n\n    <!-- 诗题 -->\n    <h1 style=\"text-align: center; font-size: 26px; color: #3d3529; margin: 14px 0 6px; letter-spacing: 6px; font-weight: 700; animation: fadeDown 0.8s ease-out;\">\n      定 风 波\n    </h1>\n    <p style=\"text-align: center; font-size: 13px; color: #8b6914; margin: 0 0 28px; letter-spacing: 2px; animation: fadeDown 0.8s ease-out 0.15s both;\">\n      ——三月七日，沙湖道中遇雨，雨具先去，同行皆狼狈，余独不觉。已而遂晴，故作此。\n    </p>\n\n    <!-- 诗文主体区：左右分栏 -->\n    <div style=\"display: flex; gap: 24px; align-items: flex-start;\">\n\n      <!-- 左：诗文本体 -->\n      <div style=\"flex: 1; min-width: 0;\">\n        <div style=\"background: rgba(255, 255, 255, 0.5); border: 1px solid rgba(180, 160, 130, 0.3); border-radius: 10px; padding: 26px 28px; position: relative; box-shadow: 2px 3px 12px rgba(61, 53, 41, 0.1); animation: contentReveal 0.8s ease-out 0.3s both;\">\n\n          <!-- 装饰性引号 -->\n          <div style=\"position: absolute; top: 8px; left: 12px; font-size: 48px; color: rgba(139, 69, 19, 0.12); font-family: Georgia, serif; line-height: 1;\">“</div>\n\n          <div style=\"font-size: 18px; line-height: 2.4; color: #2c2416; letter-spacing: 2px; text-align: center;\">\n\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 0.5s both;\">\n              <span style=\"font-size: 22px; font-weight: 600;\">莫听穿林打叶声</span><span style=\"color: #8b4513; font-size: 14px; margin-left: 4px;\">，</span>\n            </p>\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 0.65s both;\">\n              <span style=\"font-size: 22px; font-weight: 600;\">何妨吟啸且徐行</span><span style=\"color: #8b4513; font-size: 14px; margin-left: 4px;\">。</span>\n            </p>\n\n            <div style=\"height: 16px;\"></div>\n\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 0.85s both;\">\n              <span style=\"background: linear-gradient(180deg, transparent 60%, rgba(139, 69, 19, 0.15) 60%); padding: 0 2px;\">竹杖芒鞋轻胜马</span><span style=\"color: #8b4513; font-size: 14px; margin-left: 4px;\">，</span>\n            </p>\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 1.0s both;\">\n              <span style=\"color: #b22222; font-weight: 700; font-size: 22px;\">谁怕？</span>\n            </p>\n\n            <div style=\"height: 16px;\"></div>\n\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 1.2s both;\">\n              <span style=\"font-size: 22px; font-weight: 600;\">一蓑烟雨任平生</span><span style=\"color: #8b4513; font-size: 14px; margin-left: 4px;\">。</span>\n            </p>\n          </div>\n\n          <!-- 结语 -->\n          <div style=\"height: 14px;\"></div>\n          <div style=\"border-top: 1px dashed rgba(139, 69, 19, 0.2); margin: 18px 0 14px;\"></div>\n          <div style=\"font-size: 16px; line-height: 2.4; color: #2c2416; letter-spacing: 2px; text-align: center;\">\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 1.4s both;\">\n              料峭春风吹酒醒<span style=\"color: #8b4513; font-size: 14px;\">，</span>\n            </p>\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 1.55s both;\">\n              微冷<span style=\"color: #8b4513; font-size: 14px;\">，</span>\n            </p>\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 1.7s both;\">\n              山头斜照却相迎<span style=\"color: #8b4513; font-size: 14px;\">。</span>\n            </p>\n            <div style=\"height: 12px;\"></div>\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 1.9s both;\">\n              回首向来萧瑟处<span style=\"color: #8b4513; font-size: 14px;\">，</span>\n            </p>\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 2.05s both;\">\n              归去<span style=\"color: #8b4513; font-size: 14px;\">，</span>\n            </p>\n            <p style=\"margin: 0 0 4px; animation: lineReveal 0.6s ease-out 2.2s both;\">\n              <span style=\"border-bottom: 3px solid #b22222; padding-bottom: 2px;\">也无风雨也无晴</span><span style=\"color: #8b4513; font-size: 14px;\">。</span>\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <!-- 右：批注边栏 -->\n      <div style=\"width: 200px; flex-shrink: 0; animation: slideInRight 0.7s ease-out 0.8s both;\">\n\n        <!-- 批注1 -->\n        <div style=\"background: #fffef5; border-left: 3px solid #b22222; padding: 12px 14px; border-radius: 0 8px 8px 0; margin-bottom: 14px; box-shadow: 1px 2px 8px rgba(61, 53, 41, 0.08); position: relative;\">\n          <div style=\"position: absolute; top: -8px; left: 14px; background: #b22222; color: #fffef5; font-size: 10px; padding: 2px 8px; border-radius: 10px; letter-spacing: 1px;\">词眼</div>\n          <p style=\"margin: 8px 0 4px; font-size: 18px; font-weight: 700; color: #b22222; text-align: center; letter-spacing: 4px;\">谁怕</p>\n          <p style=\"margin: 0; font-size: 11px; color: #8b6914; line-height: 1.6;\">二字千钧，掷地有声。非莽夫之勇，乃通透后的释然。</p>\n        </div>\n\n        <!-- 批注2 -->\n        <div style=\"background: #fffef5; border-left: 3px solid #8b6914; padding: 12px 14px; border-radius: 0 8px 8px 0; margin-bottom: 14px; box-shadow: 1px 2px 8px rgba(61, 53, 41, 0.08);\">\n          <p style=\"margin: 0 0 6px; font-size: 12px; font-weight: 700; color: #8b6914; letter-spacing: 1px;\">典故</p>\n          <p style=\"margin: 0; font-size: 11px; color: #5a4a2e; line-height: 1.6;\"><strong>芒鞋</strong>：草鞋，隐士标配。化用〈归去来兮辞〉意象。与竹杖并举，尽写出世脱俗之态。</p>\n        </div>\n\n        <!-- 批注3 -->\n        <div style=\"background: #fffef5; border-left: 3px solid #5a7a5e; padding: 12px 14px; border-radius: 0 8px 8px 0; margin-bottom: 14px; box-shadow: 1px 2px 8px rgba(61, 53, 41, 0.08);\">\n          <p style=\"margin: 0 0 6px; font-size: 12px; font-weight: 700; color: #5a7a5e; letter-spacing: 1px;\">意象对位</p>\n          <p style=\"margin: 0; font-size: 11px; color: #5a4a2e; line-height: 1.6;\">\n            <span style=\"color: #4a6a7e;\">🜄 烟雨</span> 逆境<br>\n            <span style=\"color: #d4a03c;\">☉ 斜照</span> 转机<br>\n            <span style=\"color: #8b4513;\">∅ 萧瑟</span> 已过\n          </p>\n        </div>\n\n      </div>\n    </div>\n\n    <!-- 意象卡片区 -->\n    <div style=\"margin-top: 28px;\">\n      <div style=\"display: flex; align-items: center; gap: 8px; margin-bottom: 14px; animation: fadeIn 0.6s ease-out 1.8s both;\">\n        <div style=\"height: 1px; flex: 1; background: linear-gradient(90deg, transparent, rgba(139, 69, 19, 0.3), transparent);\"></div>\n        <span style=\"font-size: 11px; color: #8b6914; letter-spacing: 4px;\">意象图谱</span>\n        <div style=\"height: 1px; flex: 1; background: linear-gradient(90deg, transparent, rgba(139, 69, 19, 0.3), transparent);\"></div>\n      </div>\n\n      <div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;\">\n        <!-- 意象1 -->\n        <div style=\"background: rgba(255,255,255,0.6); border: 1px solid rgba(74, 106, 126, 0.2); border-radius: 10px; padding: 16px 10px; text-align: center; animation: cardAppear 0.5s ease-out 2.0s both;\">\n          <div style=\"font-size: 28px; margin-bottom: 6px;\">🌧️</div>\n          <p style=\"margin: 0; font-size: 16px; font-weight: 700; color: #3d3529; letter-spacing: 2px;\">烟雨</p>\n          <p style=\"margin: 4px 0 0; font-size: 10px; color: #8b6914;\">外境之厄</p>\n          <div style=\"mtargin-top: 6px; height: 2px; background: linear-gradient(90deg, transparent, #4a6a7e, transparent); margin-top: 6px;\"></div>\n          <p style=\"margin: 4px 0 0; font-size: 10px; color: #6b5e3e; font-style: italic;\">穿林打叶</p>\n        </div>\n        <!-- 意象2 -->\n        <div style=\"background: rgba(255,255,255,0.6); border: 1px 